<script>
  // Set today's date as default
  const today = new Date();
  document.getElementById('contract_date').value = today.toISOString().split('T')[0];

  function thaiDate(dateStr) {
    if (!dateStr) return '';
    const d = new Date(dateStr);
    const months = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน',
                    'กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
    return `${d.getDate()} ${months[d.getMonth()]} พ.ศ. ${d.getFullYear() + 543}`;
  }

  function set(id, val) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  function updateContract() {
    const v = id => document.getElementById(id).value.trim();

    const dateStr = v('contract_date');
    const payment = Number(v('payment')).toLocaleString('th-TH');

    set('c_date', thaiDate(dateStr));
    set('c_company_name', v('company_name'));
    set('c_company_name2', v('company_name'));
    set('c_company_address', v('company_address'));
    set('c_company_address2', v('company_address'));
    set('c_director', v('director_name'));
    set('c_director2', v('director_name'));

    set('c_streamer_name', v('streamer_name'));
    set('c_streamer_name2', v('streamer_name'));
    set('c_streamer_id', v('streamer_id'));
    set('c_streamer_address', v('streamer_address'));
    set('c_channel_name', v('channel_name'));
    set('c_channel_url', v('channel_url'));

    set('c_brand_name', v('brand_name'));
    set('c_brand_name2', v('brand_name'));
    set('c_brand_name3', v('brand_name'));
    set('c_brand_name4', v('brand_name'));
    set('c_brand_name5', v('brand_name'));
    set('c_brand_name6', v('brand_name'));

    set('c_website_url', v('website_url'));
    set('c_website_url2', v('website_url'));
    set('c_website_url3', v('website_url'));

    set('c_game_name', v('game_name'));
    set('c_min_content', v('min_content'));
    set('c_min_live', v('min_live_hours'));
    set('c_payment', payment);
    set('c_pay_day', v('pay_day'));
    set('c_duration', document.getElementById('contract_duration').value);

    set('c_witness1', v('witness1'));
    set('c_witness2', v('witness2'));
  }



  // Auto-update on input change
  document.querySelectorAll('#editor-panel input, #editor-panel select').forEach(el => {
    el.addEventListener('input', updateContract);
  });

  // Initial render
  updateContract();
</script>

